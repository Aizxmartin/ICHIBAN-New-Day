import io
import re
from typing import Any, Dict, List, Optional

from PyPDF2 import PdfReader


def extract_pdf_text(pdf_bytes: bytes) -> str:
    if not pdf_bytes:
        return ""

    reader = PdfReader(io.BytesIO(pdf_bytes))
    pages: List[str] = []

    for page in reader.pages:
        try:
            pages.append(page.extract_text() or "")
        except Exception:
            pages.append("")

    return "\n".join(pages)


def _clean_numeric(raw: str) -> Optional[float]:
    if not raw:
        return None
    cleaned = raw.replace('$', '').replace(',', '').strip()
    try:
        return float(cleaned)
    except ValueError:
        return None


def _clean_int(raw: str) -> Optional[int]:
    value = _clean_numeric(raw)
    if value is None:
        return None
    return int(round(value))


def _search(patterns: List[str], text: str, flags: int = re.IGNORECASE) -> Optional[str]:
    for pattern in patterns:
        match = re.search(pattern, text, flags)
        if match:
            return next((g for g in match.groups() if g is not None), None)
    return None


def _search_range(patterns: List[str], text: str, flags: int = re.IGNORECASE):
    for pattern in patterns:
        match = re.search(pattern, text, flags)
        if match:
            groups = [g for g in match.groups() if g is not None]
            if len(groups) >= 2:
                return groups[0], groups[1]
    return None, None


def parse_subject_pdf(pdf_bytes: bytes) -> Dict[str, Any]:
    text = extract_pdf_text(pdf_bytes)
    normalized_text = re.sub(r'[ 	]+', ' ', text)

    warnings: List[str] = []
    if not text.strip():
        warnings.append('No readable text was extracted from the Subject PDF.')

    realavm = _search([
        r'Real\s*AVM[^\d$]{0,30}\$?([\d,]+(?:\.\d+)?)',
        r'AVM[^\d$]{0,30}\$?([\d,]+(?:\.\d+)?)',
    ], normalized_text)

    realavm_low, realavm_high = _search_range([
        r'Real\s*AVM\s*Range[^\d$]{0,20}\$?([\d,]+)\s*(?:to|-|–|—)\s*\$?([\d,]+)',
        r'Value\s*Range[^\d$]{0,20}\$?([\d,]+)\s*(?:to|-|–|—)\s*\$?([\d,]+)',
    ], normalized_text)

    address = _search([
        r'Property Address[:\s]+(.+?)(?:\n|City[,\s])',
        r'Subject Property[:\s]+(.+?)(?:\n|City[,\s])',
        r'^(\d{2,6}[^\n]+?(?:CO\s+\d{5})?)$',
    ], text, flags=re.IGNORECASE | re.MULTILINE)

    beds = _search([r'Beds?(?:rooms)?[^\d]{0,10}([\d]+(?:\.\d+)?)'], normalized_text)
    baths = _search([r'Baths?(?:rooms)?[^\d]{0,10}([\d]+(?:\.\d+)?)'], normalized_text)
    above_grade_sf = _search([
        r'Above\s*Grade(?:\s*Finished)?\s*(?:Area|SF|Sq\.? ?Ft\.?)?[^\d]{0,10}([\d,]+)',
        r'Finished\s*Area\s*Above\s*Grade[^\d]{0,10}([\d,]+)',
    ], normalized_text)
    basement_sf = _search([
        r'Basement\s*(?:Area|SF|Sq\.? ?Ft\.?)?[^\d]{0,10}([\d,]+)',
        r'Below\s*Grade\s*(?:Area|SF|Sq\.? ?Ft\.?)?[^\d]{0,10}([\d,]+)',
    ], normalized_text)
    year_built = _search([r'Year\s*Built[^\d]{0,10}([12][09]\d{2})'], normalized_text)
    lot_size = _search([
        r'Lot\s*Size[^\d]{0,10}([\d,]+)',
        r'Site\s*(?:Area|Size)[^\d]{0,10}([\d,]+)',
    ], normalized_text)
    property_type = _search([
        r'Property\s*Type[:\s]+([^\n]+)',
        r'Style[:\s]+([^\n]+)',
        r'Use\s*Code[:\s]+([^\n]+)',
    ], text)

    result = {
        'source_text': text,
        'address': address.strip() if address else None,
        'realavm': _clean_numeric(realavm) if realavm else None,
        'realavm_low': _clean_numeric(realavm_low) if realavm_low else None,
        'realavm_high': _clean_numeric(realavm_high) if realavm_high else None,
        'beds': _clean_numeric(beds) if beds else None,
        'baths': _clean_numeric(baths) if baths else None,
        'above_grade_sf': _clean_int(above_grade_sf) if above_grade_sf else None,
        'basement_sf': _clean_int(basement_sf) if basement_sf else None,
        'year_built': _clean_int(year_built) if year_built else None,
        'lot_size': _clean_int(lot_size) if lot_size else None,
        'property_type': property_type.strip() if property_type else None,
        'warnings': warnings,
    }

    if result['realavm'] is None:
        warnings.append('RealAVM was not confidently extracted from the Subject PDF.')
    if result['realavm_low'] is None or result['realavm_high'] is None:
        warnings.append('RealAVM range was not confidently extracted from the Subject PDF.')

    return result
