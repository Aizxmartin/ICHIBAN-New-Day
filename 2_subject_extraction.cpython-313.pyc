import json

import streamlit as st

from core.intake import validate_intake
from core.subject_normalizer import build_subject_profile
from core.subject_parser import parse_subject_pdf

st.set_page_config(page_title="ICHIBAN - New Day | Subject Extraction", page_icon="🏡", layout="wide")

st.title("Module 2 — Subject Extraction + Input Normalization")
st.subheader("Turn the uploaded Subject PDF and online values into a structured subject profile")

st.markdown(
    """
This module belongs to the **private logic layer**. It reads the uploaded Subject Property PDF,
tries to extract key subject details, and combines those results with Zillow and Redfin values
already entered in Module 1.
"""
)

st.divider()

if not validate_intake(st.session_state):
    st.error("Module 1 intake is not complete yet. Please return to Module 1 and confirm the required inputs.")
    st.stop()

subject_pdf_bytes = st.session_state.get("subject_pdf_bytes")
subject_pdf_name = st.session_state.get("subject_pdf_filename", "Subject PDF")

if not subject_pdf_bytes:
    st.error("No Subject PDF bytes were found in session state. Please re-upload the subject PDF in Module 1.")
    st.stop()

with st.spinner("Extracting subject data from PDF..."):
    parsed_subject = parse_subject_pdf(subject_pdf_bytes)
    subject_profile = build_subject_profile(parsed_subject, st.session_state)

st.session_state["parsed_subject_pdf"] = parsed_subject
st.session_state["subject_profile"] = subject_profile

st.success(f"Subject extraction ran successfully for: {subject_pdf_name}")

col1, col2, col3 = st.columns(3)
col1.metric("RealAVM", f"${subject_profile['realavm']:,.0f}" if subject_profile.get('realavm') is not None else "Not found")
col2.metric("Online Estimate Average", f"${subject_profile['online_estimate_average']:,.0f}" if subject_profile.get('online_estimate_average') is not None else "Not ready")
if subject_profile.get('realavm_low') is not None and subject_profile.get('realavm_high') is not None:
    range_text = f"${subject_profile['realavm_low']:,.0f} - ${subject_profile['realavm_high']:,.0f}"
else:
    range_text = "Not found"
col3.metric("RealAVM Range", range_text)

st.divider()

st.header("A. Extracted Subject Snapshot")
left, right = st.columns(2)

with left:
    st.write(f"**Address:** {subject_profile.get('address') or 'Not found'}")
    st.write(f"**Property Type:** {subject_profile.get('property_type') or 'Not found'}")
    st.write(f"**Beds:** {subject_profile.get('beds') if subject_profile.get('beds') is not None else 'Not found'}")
    st.write(f"**Baths:** {subject_profile.get('baths') if subject_profile.get('baths') is not None else 'Not found'}")
    st.write(f"**Year Built:** {subject_profile.get('year_built') or 'Not found'}")

with right:
    st.write(f"**Above Grade SF:** {subject_profile.get('above_grade_sf') or 'Not found'}")
    st.write(f"**Basement SF:** {subject_profile.get('basement_sf') or 'Not found'}")
    st.write(f"**Lot Size:** {subject_profile.get('lot_size') or 'Not found'}")
    st.write(f"**Zillow:** {'$' + format(subject_profile['zillow'], ',.0f') if subject_profile.get('zillow') is not None else 'Not entered'}")
    st.write(f"**Redfin:** {'$' + format(subject_profile['redfin'], ',.0f') if subject_profile.get('redfin') is not None else 'Not entered'}")

st.divider()

st.header("B. Review Warnings")
if subject_profile.get('warnings'):
    for warning in subject_profile['warnings']:
        st.warning(warning)
else:
    st.success("No extraction warnings were raised.")

st.divider()

st.header("C. Structured Subject Profile")
st.caption("This normalized object is intended to hand off cleanly into later comp filtering and valuation modules.")
st.json(subject_profile)

st.divider()

st.header("D. Raw Extracted Text Preview")
show_text = st.checkbox("Show extracted PDF text", value=False)
if show_text:
    st.text_area("Extracted Text", value=parsed_subject.get('source_text', ''), height=300)

st.divider()

if st.button("Confirm Subject Profile", type="primary"):
    st.session_state['subject_profile_confirmed'] = True
    st.success("Module 2 complete. Subject profile is ready for later modules.")
